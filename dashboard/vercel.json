{
  "framework": "nextjs",
  "functions": {
    "src/app/api/**/*.ts": {
      "memory": 512,
      "maxDuration": 60
    },
    "src/app/api/pipeline/jobs/**/run/route.ts": {
      "memory": 1024,
      "maxDuration": 120
    },
    "src/app/api/pipeline/trigger/route.ts": {
      "memory": 1024,
      "maxDuration": 120
    }
  },
  "headers": [
    {
      "source": "/api/system/status",
      "headers": [{ "key": "Cache-Control", "value": "s-maxage=30, stale-while-revalidate=60" }]
    }
  ]
}
