generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Newsletter {
  id                  Int    @id
  issueNumber         Int    @map("issue_number")
  issueDate           String @map("issue_date")
  status              String
  mailchimpCampaignId String? @map("mailchimp_campaign_id")
  createdAt           String @map("created_at")
  updatedAt           String @map("updated_at")

  @@index([issueDate])
  @@index([status])
  @@map("newsletters")
}

model Draft {
  id            Int    @id
  newsletterId  Int    @map("newsletter_id")
  rawData       String @map("raw_data")
  aiDraft       String @map("ai_draft")
  humanEdits    String? @map("human_edits")
  status        String
  reviewerEmail String? @map("reviewer_email")
  reviewedAt    String? @map("reviewed_at")
  sourcesUsed   String? @map("sources_used")
  sourcesWarning String? @map("sources_warning")
  sourcesFailed String? @map("sources_failed")
  createdAt     String @map("created_at")
  updatedAt     String @map("updated_at")

  @@index([newsletterId])
  @@index([status])
  @@map("drafts")
}

model Article {
  id            Int    @id
  newsletterId  Int    @map("newsletter_id")
  sectionType   String @map("section_type")
  title         String
  teaser        String
  body          String
  audienceTag   String @map("audience_tag")
  publishDate   String? @map("publish_date")
  msPlatformUrl String? @map("ms_platform_url")
  createdAt     String @map("created_at")

  @@index([newsletterId])
  @@map("articles")
}

model ApprovalLog {
  id       Int    @id
  draftId  Int    @map("draft_id")
  action   String
  reviewer String
  notes    String?
  timestamp String

  @@index([draftId])
  @@index([timestamp])
  @@map("approval_logs")
}

model WorkflowLog {
  id          String @id
  timestamp   String
  scope       String
  step        String
  status      String
  message     String
  contextJson String? @map("context_json")

  @@index([timestamp])
  @@index([scope, step])
  @@map("workflow_logs")
}

model PipelineJob {
  id            String  @id
  status        String
  force         Boolean @default(false)
  requestedBy   String? @map("requested_by")
  startedAt     String? @map("started_at")
  completedAt   String? @map("completed_at")
  createdAt     String  @map("created_at")
  updatedAt     String  @map("updated_at")
  resultJson    String? @map("result_json")
  errorDetail   String? @map("error_detail")
  leaseExpiresAt String? @map("lease_expires_at")

  @@index([status, createdAt])
  @@map("pipeline_jobs")
}

model LoginAttempt {
  key            String @id
  attempts       Int    @default(0)
  windowStartedAt String @map("window_started_at")
  blockedUntil   String? @map("blocked_until")
  updatedAt      String @map("updated_at")

  @@index([blockedUntil])
  @@map("login_attempts")
}
